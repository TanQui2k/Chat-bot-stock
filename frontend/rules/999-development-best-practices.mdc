## 🔒 Best Practices Bảo Mật

### Authentication & Authorization
```typescript
// ✅ ĐÚNG: Lưu tokens an toàn với Zustand
import { create } from 'zustand';
import { persist } from 'zustand/middleware';

interface AuthState {
  accessToken: string | null;
  refreshToken: string | null;
  setTokens: (access: string, refresh: string) => void;
  clearTokens: () => void;
}

export const useAuthStore = create<AuthState>()(
  persist(
    (set) => ({
      accessToken: null,
      refreshToken: null,
      setTokens: (access, refresh) => set({ accessToken: access, refreshToken: refresh }),
      clearTokens: () => set({ accessToken: null, refreshToken: null }),
    }),
    {
      name: 'auth-storage',
    }
  )
);

// ✅ ĐÚNG: Tự động thêm auth headers với interceptor (xem src/api/interceptors.ts)
axiosInstance.interceptors.request.use((config) => {
  const token = useAuthStore.getState().accessToken;
  if (token) {
    config.headers.Authorization = `Bearer ${token}`;
  }
  return config;
});

// ❌ SAI: Quản lý token thủ công trong mỗi request
const fetchData = async () => {
  const token = localStorage.getItem('token');  // Lấy token thủ công
  const response = await fetch('/api/data', {
    headers: { Authorization: `Bearer ${token}` },  // Set header thủ công
  });
};
```

### Validation & Sanitization Input
```typescript
// ✅ ĐÚNG: Validate và sanitize user input
import DOMPurify from 'dompurify';

const SafeContent: FC<{ content: string }> = ({ content }) => (
  <div dangerouslySetInnerHTML={{ __html: DOMPurify.sanitize(content) }} />
);

// ✅ ĐÚNG: Dùng react-hook-form với validation
import { useForm } from 'react-hook-form';

interface FormData {
  email: string;
  message: string;
}

const Form = () => {
  const { register, handleSubmit, formState: { errors } } = useForm<FormData>();

  const onSubmit = (data: FormData) => {
    // Data đã được validate
  };

  return (
    <form onSubmit={handleSubmit(onSubmit)}>
      <input
        {...register('email', {
          required: 'Email bắt buộc',
          pattern: {
            value: /^[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}$/i,
            message: 'Email không hợp lệ',
          },
        })}
      />
      {errors.email && <span>{errors.email.message}</span>}
    </form>
  );
};

// ❌ SAI: Không có validation
const Form = () => {
  const [email, setEmail] = useState('');

  const handleSubmit = () => {
    sendEmail(email);  // Không validate!
  };
};
```

