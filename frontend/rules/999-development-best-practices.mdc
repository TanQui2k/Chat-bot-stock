## 🧪 Pattern Xử Lý Lỗi

### Xử Lý Lỗi API
```typescript
// ✅ ĐÚNG: Xử lý lỗi tập trung với interceptors (src/api/interceptors.ts)
axiosInstance.interceptors.response.use(
  (response) => response,
  async (error) => {
    if (error.response?.status === 401) {
      // Auto refresh token
      const refreshed = await refreshAccessToken();
      if (refreshed) {
        return axiosInstance.request(error.config);
      }
      // Redirect về login
      window.location.href = '/login';
    }

    // Hiển thị error message thân thiện
    const message = error.response?.data?.message || t('errors.somethingWentWrong');
    toast.error(message);

    return Promise.reject(error);
  }
);

// ✅ ĐÚNG: Xử lý errors trong components
const Component = () => {
  const { data, error, isLoading } = useApiGet('/api/data');

  if (isLoading) return <LoadingSpinner />;
  if (error) return <ErrorMessage message={error.message} />;

  return <DataDisplay data={data} />;
};

// ❌ SAI: Im lặng nuốt errors
const Component = () => {
  try {
    const data = await fetchData();
  } catch (error) {
    // Không làm gì - user không biết có lỗi
  }
};
```

### Xử Lý Lỗi Form
```typescript
// ✅ ĐÚNG: Hiển thị validation errors cho users
import { useForm } from 'react-hook-form';
import { toast } from 'sonner';

const Form = () => {
  const { register, handleSubmit, formState: { errors } } = useForm();

  const onSubmit = async (data) => {
    try {
      await sendMessage(data);
      toast.success(t('messages.sentSuccessfully'));
    } catch (error) {
      toast.error(t('messages.sendFailed'));
    }
  };

  return (
    <form onSubmit={handleSubmit(onSubmit)}>
      <input {...register('message', { required: t('validation.required') })} />
      {errors.message && <span className="text-destructive">{errors.message.message}</span>}
    </form>
  );
};
```

