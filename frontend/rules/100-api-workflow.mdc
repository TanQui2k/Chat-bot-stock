## 3. Define Query Keys
Add query keys in `src/services/queryKeys.ts`:

```typescript
import { createQueryKeyStore } from '@lukemorales/query-key-factory';

export const queryKeys = createQueryKeyStore({
  articles: {
    all: null,
    detail: (id: string | number) => [id],
    list: (params: any) => [params],
  },
  chat: {
    all: null,
    history: null,
    detail: (id: string) => [id],
  },
  user: {
    all: null,
    profile: null,
  },
});

export type QueryItem = {
  name: keyof typeof queryKeys;
  type: string;
  params?: any[];
};
```

## 4. Create Custom Hooks for API Calls

### GET Hook Example
```typescript
// src/hooks/useArticles.ts
import { useApiGet } from '@/hooks/useApiGet';
import type { Article, ArticleListParams } from '@/interfaces';

export function useArticles(params?: ArticleListParams) {
  return useApiGet<Article[]>(
    '/api/articles',
    'articles',
    'list',
    null,
    params,
    'always', // refetchOnMount
    2 * 60 * 1000, // gcTime (2 minutes)
    true // enabled
  );
}

export function useArticle(id: string | number) {
  return useApiGet<Article>(
    `/api/articles/${id}`,
    'articles',
    'detail',
    id,
    undefined,
    'always',
    5 * 60 * 1000, // 5 minutes cache
    !!id // only enabled if id exists
  );
}
```

### POST/PUT/DELETE Hook Example
```typescript
// src/hooks/useArticleMutations.ts
import { useApiPost } from '@/hooks/useApiPost';
import type { ArticleCreateRequest, ArticleUpdateRequest } from '@/interfaces';

/**
 * Create article mutation
 */
export function useCreateArticle() {
  return useApiPost(
    '/api/articles',
    [{ name: 'articles', type: 'all' }], // Invalidate articles list after creation
    'post'
  );
}

/**
 * Update article mutation
 */
export function useUpdateArticle(id: string | number) {
  return useApiPost(
    `/api/articles/${id}`,
    [
      { name: 'articles', type: 'all' },
      { name: 'articles', type: 'detail' }
    ],
    'put'
  );
}

/**
 * Delete article mutation
 */
export function useDeleteArticle(id: string | number) {
  return useApiPost(
    `/api/articles/${id}`,
    [{ name: 'articles', type: 'all' }],
    'delete'
  );
}

/**
 * Upload article with image (FormData)
 */
export function useUploadArticle() {
  return useApiPost(
    '/api/articles/upload',
    [{ name: 'articles', type: 'all' }],
    'post',
    true // isFormData flag
  );
}
```

## 5. Use in React Components
Implement in components with proper error handling:

```typescript
// src/app/articles/page.tsx
'use client';

import { useArticles } from '@/hooks/useArticles';
import { useCreateArticle, useDeleteArticle } from '@/hooks/useArticleMutations';
import type { ArticleCreateRequest } from '@/interfaces';
import { Button } from '@/components/ui/button';
import { toast } from 'sonner';

export default function ArticlesPage() {
  const { data, isLoading, error, refetch } = useArticles({ publishedOnly: false });
  const createMutation = useCreateArticle();
  const deleteMutation = useDeleteArticle(1);

  const handleCreate = async () => {
    const articleData: ArticleCreateRequest = {
      title: 'New Article',
      content: 'Article content here',
      isPublished: true,
    };

    try {
      const result = await createMutation.mutateAsync(articleData);

      if (result.success) {
        toast.success(result.message || 'Article created successfully');
      } else {
        toast.error(result.message || 'Failed to create article');
      }
    } catch (err) {
      // Error is already handled by useApiPost hook
      console.error('Create article error:', err);
    }
  };

  const handleDelete = async (id: number) => {
    try {
      const result = await deleteMutation.mutateAsync({});

      if (result.success) {
        toast.success('Article deleted successfully');
      }
    } catch (err) {
      console.error('Delete article error:', err);
    }
  };

  if (isLoading) {
    return <div>Loading articles...</div>;
  }

  if (error) {
    return <div>Error loading articles: {error.message}</div>;
  }

  return (
    <div className="container mx-auto p-4">
      <div className="flex justify-between items-center mb-4">
        <h1 className="text-2xl font-bold">Articles</h1>
        <Button
          onClick={handleCreate}
          disabled={createMutation.isPending}
        >
          {createMutation.isPending ? 'Creating...' : 'Create Article'}
        </Button>
      </div>

      <div className="grid gap-4">
        {data?.data?.map((article) => (
          <div key={article.id} className="border p-4 rounded-lg">
            <h2 className="text-xl font-semibold">{article.title}</h2>
            <p className="text-gray-600 mt-2">{article.content}</p>
            <div className="flex gap-2 mt-4">
              <Button
                variant="destructive"
                onClick={() => handleDelete(article.id)}
                disabled={deleteMutation.isPending}
              >
                Delete
              </Button>
            </div>
          </div>
        ))}
      </div>
    </div>
  );
}
```

## API Response Standards

### Success Response
```typescript
{
  success: true,
  data: T, // Your data
  message: "Operation successful"
}
```

### Error Response
```typescript
{
  success: false,
  message: "Error message",
  errors?: any // Optional detailed errors
}
```

## Error Handling Architecture

### 1. API Layer (src/api/index.ts)
- Axios interceptors handle token injection
- Response interceptor transforms errors
- `handleError` utility normalizes error format

### 2. Hook Layer (useApiGet, useApiPost)
- `useApiGet`: Uses `throwOnError: true` for React Query
- `useApiPost`: Has built-in `onError` handler with toast notification
- Errors are caught and displayed to users automatically

### 3. Component Layer
- Use try-catch for explicit error handling
- Access mutation errors via `mutation.error`
- Use loading states via `isLoading`, `isPending`

